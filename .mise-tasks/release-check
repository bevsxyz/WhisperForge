#!/usr/bin/env bash
# mise description="Pre-release gate: compile all variants, smoke test error paths — run before tagging"
set -euo pipefail

cd "$(git rev-parse --show-toplevel)"

# ── 1. Compile ────────────────────────────────────────────────────────────────
echo "=== [1/2] Compile"

# Default (GPU) variant — mirrors what Linux/macOS release build uses
cargo build --release -p whisperforge --features gpu

# CPU-only variant — mirrors Windows release build; catches --no-default-features regressions
cargo build --release -p whisperforge --no-default-features

# ── 2. Smoke tests ────────────────────────────────────────────────────────────
echo "=== [2/2] Smoke tests"
BIN="./target/release/wf"

"$BIN" --help > /dev/null
"$BIN" transcribe --help > /dev/null
"$BIN" convert --help > /dev/null
"$BIN" list-models --help > /dev/null

CARGO_VER=$(grep '^version' Cargo.toml | head -1 | grep -oP '"\K[^"]+')
BIN_VER=$("$BIN" --version 2>&1 | grep -oP '\d+\.\d+\.\d+' | head -1)
[[ "$CARGO_VER" == "$BIN_VER" ]] || {
    echo "FAIL: version mismatch — Cargo.toml=$CARGO_VER binary=$BIN_VER"
    exit 1
}

# Missing audio → must exit nonzero
"$BIN" transcribe -a /no_such_audio_file_9999.wav -m tiny_en_converted && {
    echo "FAIL: missing audio was accepted (expected nonzero exit)"
    exit 1
} || true

# Missing model → must exit nonzero with friendly error
"$BIN" transcribe -a /dev/null -m no_such_model_xyz && {
    echo "FAIL: missing model was accepted (expected nonzero exit)"
    exit 1
} || true

echo ""
echo "=== Release check PASSED ==="
