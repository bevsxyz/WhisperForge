# Generated by Cargo
# will have compiled files and executables
debug/
target/

# These are backup files generated by rustfmt
**/*.rs.bk

# MSVC Windows builds of rustc generate these, which store debugging information
*.pdb

# Generated by cargo mutants
# Contains mutation testing data
**/mutants.out*/

# Temporary / generated test files (not the committed LJSpeech fixtures)
*.tmp.wav
test_data/*_16k.wav
# …except the LJ001-0001 16 kHz clip — a required fixture for the streaming
# integration tests and scripts/uat-stream.ps1 (FakeMic needs exactly 16 kHz).
!test_data/LJ001-0001_16k.wav

# Audio inputs (MP3 support planned)
*.mp3

# Model files (large binaries)
models/
*.mpk
*.safetensors

# IDE files
.vscode/
.idea/
*.swp
*.swo

# OS files
.DS_Store
Thumbs.db

# RustRover/JetBrains (optional, uncomment if using)
# .idea/

# Auto-generated repo map (derived artifact)
CODEINDEX.md
whisperforge/CHANGELOG.md
whisperforge-*/CHANGELOG.md

# Claude harness runtime artifacts
.claude/scheduled_tasks.lock
